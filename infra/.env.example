# Laminar self-hosted compose settings.
# Copy to infra/.env with `make laminar-env`, then set LMNR_PROJECT_API_KEY
# after creating a project/API key in the Laminar UI.

POSTGRES_USER=lmnr
POSTGRES_PASSWORD=
POSTGRES_DB=lmnr

CLICKHOUSE_USER=lmnr
CLICKHOUSE_PASSWORD=
CLICKHOUSE_RO_USER=lmnr_ro
CLICKHOUSE_RO_PASSWORD=

SHARED_SECRET_TOKEN=
AEAD_SECRET_KEY=
NEXTAUTH_SECRET=

FRONTEND_HOST_PORT=5667
APP_SERVER_HOST_PORT=18000
APP_SERVER_GRPC_HOST_PORT=18001
APP_SERVER_RT_HOST_PORT=18002
QUERY_ENGINE_HOST_PORT=8903

# Optional model provider keys used by Laminar itself.
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# AlphaOPT Laminar client settings.
LMNR_PROJECT_API_KEY=
ALPHAOPT_LAMINAR_ENABLED=1
ALPHAOPT_LAMINAR_FAIL_FAST=1
ALPHAOPT_LAMINAR_BASE_URL=http://localhost
ALPHAOPT_LAMINAR_HTTP_PORT=18000
ALPHAOPT_LAMINAR_GRPC_PORT=18001
ALPHAOPT_LAMINAR_EXPORT_TIMEOUT_SECONDS=5
ALPHAOPT_LAMINAR_CAPTURE_IO=1
